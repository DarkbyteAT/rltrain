{
    "fqn": "rltrain.agents.actor_critic.AdvantageAC",
    "beta_critic": 0.5,
    "gamma": 0.99,
    "lambda_gae": 0.9,
    "tau": 0.01,
    "horizon": 128,
    "normalise": false,
    "robust": true,
    "rho_sam": 1e-2,
    "rollback_len": 0,
	"model": {
        "actor": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 7,
                "hiddens": [256, 256, 256, 256],
                "outputs": 2
            }
        ],
        "critic": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 7,
                "hiddens": [256, 256, 256, 256],
                "outputs": 1
            }
        ]
    },
    "opt": {
        "actor": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        },
        "critic": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        }
    }
}