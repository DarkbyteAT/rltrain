{
    "fqn": "rltrain.agents.actor_critic.PPO",
    "beta_critic": 0.5,
    "gamma": 0.995,
    "lambda_gae": 0.9,
    "tau": 0.05,
    "early_stop": 0.05,
    "eps_clip": 0.2,
    "horizon": 128,
    "num_epochs": 8,
    "batch_size": 64,
    "normalise": false,
    "grad_transforms": [
        {"fqn": "rltrain.transforms.SAM", "rho": 1e-2},
        {"fqn": "rltrain.transforms.LAMPRollback", "eps": 5e-3, "rollback_len": 10}
    ],
	"shared_features": true,
    "model": {
        "embedding": [
            {
                "fqn": "rltrain.nn.cnn",
                "channels": [4, 16, 32],
                "kernels": [2, 2],
                "strides": [2, 1]
            }
        ],
        "actor": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 512,
                "hiddens": [256, 256, 256, 256],
                "outputs": 3
            }
        ],
        "critic": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 512,
                "hiddens": [256, 256, 256, 256],
                "outputs": 1
            }
        ]
    },
    "opt": {
        "actor": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        },
        "critic": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        }
    }
}
