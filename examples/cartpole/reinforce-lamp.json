{
  "fqn": "rltrain.agents.policy_gradient.REINFORCE",
  "beta_critic": 0.5,
  "gamma": 0.995,
  "tau": 5e-3,
  "grad_transforms": [
    {
      "fqn": "samgria.SAM",
      "rho": 1e-2
    },
    {
      "fqn": "samgria.LAMPRollback",
      "eps": 5e-3,
      "rollback_len": 10
    }
  ],
  "model": {
    "actor": [
      {
        "fqn": "toblox.SkipMLP",
        "inputs": 4,
        "hiddens": [
          256,
          256,
          256,
          256
        ],
        "outputs": 2
      }
    ],
    "critic": [
      {
        "fqn": "toblox.SkipMLP",
        "inputs": 4,
        "hiddens": [
          256,
          256,
          256,
          256
        ],
        "outputs": 1
      }
    ]
  },
  "opt": {
    "actor": {
      "fqn": "torch.optim.Adam",
      "lr": 3e-4
    },
    "critic": {
      "fqn": "torch.optim.Adam",
      "lr": 3e-4
    }
  }
}
