{
  "fqn": "rltrain.agents.actor_critic.PPO",
  "beta_critic": 0.5,
  "gamma": 0.995,
  "lambda_gae": 0.9,
  "tau": 5e-3,
  "early_stop": 0.05,
  "eps_clip": 0.2,
  "horizon": 256,
  "num_epochs": 8,
  "batch_size": 128,
  "normalise": true,
  "model": {
    "actor": [
      {
        "fqn": "toblox.SkipMLP",
        "inputs": 4,
        "hiddens": [
          256,
          256,
          256,
          256
        ],
        "outputs": 2
      }
    ],
    "critic": [
      {
        "fqn": "toblox.SkipMLP",
        "inputs": 4,
        "hiddens": [
          256,
          256,
          256,
          256
        ],
        "outputs": 1
      }
    ]
  },
  "opt": {
    "actor": {
      "fqn": "torch.optim.Adam",
      "lr": 3e-4
    },
    "critic": {
      "fqn": "torch.optim.Adam",
      "lr": 3e-4
    }
  }
}
