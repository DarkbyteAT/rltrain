{
    "fqn": "rltrain.agents.actor_critic.PPO",
    "beta_critic": 0.5,
    "gamma": 0.995,
    "lambda_gae": 0.9,
    "tau": 0.01,
    "early_stop": 0.05,
    "eps_clip": 0.2,
    "horizon": 256,
    "num_epochs": 8,
    "batch_size": 128,
    "normalise": true,
    "robust": true,
    "rho_sam": 1e-2,
    "rollback_len": 0,
	"model": {
        "actor": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 6,
                "hiddens": [256, 256, 256, 256],
                "outputs": 3
            }
        ],
        "critic": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 6,
                "hiddens": [256, 256, 256, 256],
                "outputs": 1
            }
        ]
    },
    "opt": {
        "actor": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        },
        "critic": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        }
    }
}