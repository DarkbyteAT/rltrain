{
    "fqn": "rltrain.agents.actor_critic.AdvantageAC",
    "beta_critic": 0.5,
    "gamma": 0.995,
    "lambda_gae": 0.9,
    "tau": 0.01,
    "horizon": 128,
    "normalise": false,
    "robust": true,
    "eps_lamp": 5e-3,
    "rho_sam": 1e-2,
    "rollback_len": 10,
	"model": {
        "actor": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 4,
                "hiddens": [256, 256, 256, 256],
                "outputs": 3
            }
        ],
        "critic": [
            {
                "fqn": "rltrain.nn.SkipMLP",
                "inputs": 4,
                "hiddens": [256, 256, 256, 256],
                "outputs": 1
            }
        ]
    },
    "opt": {
        "actor": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        },
        "critic": {
            "fqn": "torch.optim.Adam",
            "lr": 3e-4
        }
    }
}